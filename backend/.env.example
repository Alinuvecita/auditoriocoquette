PORT=3000

# PostgreSQL local, Aiven, Render, Supabase, Neon, etc.
DATABASE_URL=postgres://usuario:password@host:5432/auditorio_uni

# Clave larga para firmar tokens JWT
JWT_SECRET=cambia_esto_por_una_clave_larga_y_secreta

# URL donde corre el frontend con Live Server
FRONTEND_URL=http://127.0.0.1:5500/frontend

# Configuración de correo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
MAIL_FROM="Auditorio uni <tu_correo@gmail.com>"

# Usuario administrador inicial
ADMIN_EMAIL=admin@uni.edu
ADMIN_PASSWORD=Admin123*
ADMIN_NAME=Admin Auditorio
